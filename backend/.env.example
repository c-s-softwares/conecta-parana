# Database
DATABASE_URL=postgresql://user:password@localhost:5432/conecta_parana?schema=public

# Server
PORT=3000
NODE_ENV=development

# Security
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
CORS_ORIGIN=http://localhost:4200,https://admin.conecta.com,https://app.conecta.com,http://localhost:3000

# Redis (cache)
REDIS_URL=redis://localhost:6379

# GlitchTip — APM / Error Tracking
# DSN gerado no dashboard do GlitchTip (ver docs/GLITCHTIP_SETUP.md)
GLITCHTIP_DSN=

# Secrets
JWT_SECRET=minha_chave_secreta_local
JWT_REFRESH_SECRET=minha_chave_refresh_local

# Seed de super admin (usado em backend/prisma/seed-admin.ts)
ADMIN_SEED_EMAIL=admin@conecta.local
ADMIN_SEED_PASSWORD=admin123
ADMIN_SEED_NAME=Admin